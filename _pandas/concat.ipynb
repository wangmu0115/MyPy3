   "id": "8830f300-df6c-4d05-be78-633ece621a20",
   "metadata": {},
   "outputs": [],
   "source": [
    "def make_df(columns, index):\n",
    "    data = {column: [str(column) + str(i) for i in index] for column in columns}\n",
    "    return pd.DataFrame(data, index=index, columns=columns)"
   ]
  },
